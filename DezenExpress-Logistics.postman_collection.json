    },
    {
      "name": "Admin",
      "description": "Admin-only endpoints. Requires a JWT belonging to a user with the admin role.",
      "item": [
        {
          "name": "Verify / Reject Provider",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"verified\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/logistics/providers/{{providerId}}/verify",
              "host": ["{{baseUrl}}"],
              "path": ["logistics", "providers", "{{providerId}}", "verify"]
            },
            "description": "Approve or reject a logistics provider. status must be \"verified\" or \"rejected\". Only accessible by users with the admin role."
          },
          "response": [
            {
              "name": "200 OK — verified",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"status\": \"success\",\n  \"data\": {\n    \"provider\": {\n      \"_id\": \"665f1a2b3c4d5e6f7a8b9c0d\",\n      \"name\": \"GIG Logistics Nigeria\",\n      \"verificationStatus\": \"verified\"\n    }\n  }\n}"
            },
            {
              "name": "403 Forbidden",
              "status": "Forbidden",
              "code": 403,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"status\": \"fail\",\n  \"message\": \"You do not have permission to perform this action\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Location Reference",
      "description": "Public endpoints for Nigeria states and LGAs — use to populate dropdowns.",
      "item": [
        {
          "name": "Get All States",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/logistics/locations/states",
              "host": ["{{baseUrl}}"],
              "path": ["logistics", "locations", "states"]
            },
            "description": "Returns all 36 Nigerian states plus FCT Abuja as a flat array of strings."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"status\": \"success\",\n  \"results\": 37,\n  \"data\": {\n    \"states\": [\n      \"Abia\", \"Adamawa\", \"Akwa Ibom\", \"Anambra\", \"Bauchi\",\n      \"Bayelsa\", \"Benue\", \"Borno\", \"Cross River\", \"Delta\",\n      \"Ebonyi\", \"Edo\", \"Ekiti\", \"Enugu\", \"FCT\",\n      \"Gombe\", \"Imo\", \"Jigawa\", \"Kaduna\", \"Kano\",\n      \"Katsina\", \"Kebbi\", \"Kogi\", \"Kwara\", \"Lagos\",\n      \"Nasarawa\", \"Niger\", \"Ogun\", \"Ondo\", \"Osun\",\n      \"Oyo\", \"Plateau\", \"Rivers\", \"Sokoto\", \"Taraba\",\n      \"Yobe\", \"Zamfara\"\n    ]\n  }\n}"
